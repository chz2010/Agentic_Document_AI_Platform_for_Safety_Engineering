OPENAI_API_KEY=

# OpenAI-powered answer generation is used when OPENAI_API_KEY is set.
# Without a key, the app uses deterministic local hash embeddings and
# evidence-based draft answers so the workflow remains testable.
USE_OPENAI_GENERATION=true
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Local development can omit DATABASE_URL to use ./data/safety_platform.db.
# Docker Compose overrides this with PostgreSQL.
DATABASE_URL=
UPLOADS_DIR=./data/uploads
PROJECT_CHROMA_PATH=./vectordb/project_docs
PROJECT_COLLECTION_NAME=project_documents
PROJECT_DOC_CHUNK_SIZE=900
PROJECT_DOC_CHUNK_OVERLAP=120
PROJECT_RETRIEVAL_K=6
