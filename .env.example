OPENAI_API_KEY=

# Answer generation mode:
# - none: deterministic evidence synthesis, no LLM required
# - openai: OpenAI chat model, requires OPENAI_API_KEY
# - local: Ollama-compatible local model
ANSWER_MODE=none
USE_OPENAI_GENERATION=true
LLM_MODEL=gpt-4o-mini
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen2.5:7b-instruct
LOCAL_LLM_TIMEOUT=120
LOCAL_LLM_NUM_PREDICT=1200
EMBEDDING_MODEL=text-embedding-3-small

# Local development can omit DATABASE_URL to use ./data/safety_platform.db.
# Docker Compose overrides this with PostgreSQL.
DATABASE_URL=
UPLOADS_DIR=./data/uploads
PROJECT_CHROMA_PATH=./vectordb/project_docs
PROJECT_COLLECTION_NAME=project_documents
PROJECT_DOC_CHUNK_SIZE=900
PROJECT_DOC_CHUNK_OVERLAP=120
PROJECT_RETRIEVAL_K=6
